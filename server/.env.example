# MongoDB Atlas 連接字串
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bluehouse-guild?retryWrites=true&w=majority

# 伺服器端口
PORT=3000

# JWT 密鑰 (請使用長隨機字串，至少 32 字元)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 初始管理員帳密 (僅用於首次建立，可選)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
